# Bản AWS Secrets Manager thật. Copy thành secret-store.yaml khi chạy trên cụm có AWS.
# minikube (không IRSA): auth.secretRef trỏ Secret `aws-creds` (tạo bằng
#   kubectl create secret generic aws-creds -n demo \
#     --from-literal=access-key=... --from-literal=secret-key=...   # KHÔNG commit
# EKS: thay bằng auth.jwt.serviceAccountRef (IRSA).
apiVersion: external-secrets.io/v1beta1
kind: SecretStore
metadata:
  name: aws-store
  namespace: demo
spec:
  provider:
    aws:
      service: SecretsManager
      region: ap-southeast-1
      auth:
        secretRef:
          accessKeyIDSecretRef:
            name: aws-creds
            key: access-key
          secretAccessKeySecretRef:
            name: aws-creds
            key: secret-key
